TARGET = example
######## for v003 #########
OPT = -O2
FORGDB = -g

CHIP = CH32V00X
LDSCRIPT = V0_Link.ld
OCDSCRIPT = wch-riscv.cfg
#TARGET
#|  Makefile
#|  SOURSE_DIR
#|  |  main.cpp
#|  |  LIB1          -|-SRC_DIRS
#|  |  |  LIB1.h      |
#|  |  |  LIB1.cpp    |
#|  |  LIB2          -|
#|  |  |  LIB2.h      |
#|  |  |  LIB2.cpp    |
#|  |  CORE_DIR      -|
#|  |  |  core_riscv.h
#|  |  |  startup.S     - ASM_SOURSES

SOURCE_DIR = ./src
BUILD_DIR = ./build
#Subdirectories
SRC_DIRS := $(filter-out $(wildcard $(SOURCE_DIR)/*.*), $(wildcard $(SOURCE_DIR)/*))
SRC_DIRS := $(subst $(SOURCE_DIR)/,,$(SRC_DIRS))

####### find files ######
C_SOURCES = $(wildcard $(SOURCE_DIR)/*.c) $(foreach DIR, $(SRC_DIRS), $(wildcard $(SOURCE_DIR)/$(DIR)/*.c))
CPP_SOURCES = $(wildcard $(SOURCE_DIR)/*.cpp) $(foreach DIR, $(SRC_DIRS), $(wildcard $(SOURCE_DIR)/$(DIR)/*.cpp))
ASM_SOURCES = ./src/core/startup_ch32v00x.S #$(wildcard $(SOURCE_DIR)/*.S) $(foreach DIR, $(SRC_DIRS), $(wildcard $(SOURCE_DIR)/$(DIR)/*.S))

VPATH = $(SOURCE_DIR) $(addprefix $(SOURCE_DIR)/, $(SRC_DIRS))

C_SOURCES := $(notdir $(C_SOURCES))
CPP_SOURCES := $(notdir $(CPP_SOURCES))
ASM_SOURCES := $(notdir $(ASM_SOURCES))

OBJECTS := $(addprefix $(BUILD_DIR)/, $(C_SOURCES:.c=.o))
OBJECTS += $(addprefix $(BUILD_DIR)/, $(CPP_SOURCES:.cpp=.o))
OBJECTS += $(addprefix $(BUILD_DIR)/, $(ASM_SOURCES:.S=.o))

####### compilators ######
#if they aren`t in path:
RISCV_DIR = 
OPENOCD_DIR = 

CC = riscv-wch-elf-gcc
CCP = riscv-wch-elf-c++
AS = riscv-wch-elf-gcc -x assembler-with-cpp
CP = riscv-wch-elf-objcopy
SZ = riscv-wch-elf-size

OCD = openocd

####### flags ######
HEX = $(CP) -O ihex
BIN = $(CP) -O binary -S

# For gcc v12 and above (else: -march=rv32imac)
# CPU = -march=rv32imac_zicsr -mabi=ilp32 -msmall-data-limit=8
# v003 : CPU = -march=rv32ec_zicsr -mabi=ilp32e -msmall-data-limit=8
# v203 : CPU = -march=rv32imac_zicsr -mabi=ilp32e -msmall-data-limit=8
CPU = -march=rv32ec_zicsr -mabi=ilp32e -msmall-data-limit=8
CPU_LD = -march=rv32ec -mabi=ilp32e -msmall-data-limit=8

AS_INCLUDES =
C_INCLUDES = -I$(SOURCE_DIR) $(addprefix -I$(SOURCE_DIR)/, $(SRC_DIRS)) -D$(CHIP)

ASFLAGS = $(CPU) $(AS_INCLUDES) $(OPT) $(FORGDB) -Wall -fdata-sections -ffunction-sections
CFLAGS = $(CPU) $(C_INCLUDES) $(OPT) $(FORGDB) -Wall -fdata-sections -ffunction-sections \
	#-fno-use-cxa-atexit

CFLAGS += -MMD -MP -MF"$(@:%.o=%.d)"


LIBS = -lc -lm -lnosys #-nostdlib
LDFLAGS = $(CPU_LD) -mno-save-restore -fmessage-length=0 -fsigned-char -ffunction-sections -fdata-sections \
   -Wunused -Wuninitialized -T $(LDSCRIPT) -nostartfiles -Xlinker --gc-sections -Wl,-Map=$(BUILD_DIR)/$(TARGET).map --specs=nano.specs $(LIBS)

####################################################################################################
all: $(BUILD_DIR)/$(TARGET).elf $(BUILD_DIR)/$(TARGET).hex $(BUILD_DIR)/$(TARGET).bin


$(BUILD_DIR)/%.o: %.c %.h Makefile | $(BUILD_DIR)
	$(CC) -c $(CFLAGS) -Wa,-a,-ad,-alms=$(BUILD_DIR)/$(notdir $(<:.c=.lst)) $< -o $@

$(BUILD_DIR)/%.o: %.cpp Makefile | $(BUILD_DIR)
	$(CCP) -c $(CFLAGS) -Wa,-a,-ad,-alms=$(BUILD_DIR)/$(notdir $(<:.cpp=.lst)) $< -o $@

$(BUILD_DIR)/%.o: %.S Makefile | $(BUILD_DIR)
	$(AS) -c $(ASFLAGS) $< -o $@

$(BUILD_DIR)/$(TARGET).elf: $(OBJECTS) Makefile
	$(CC) $(OBJECTS) $(LDFLAGS) -o $@
	$(SZ) $@

$(BUILD_DIR)/%.hex: $(BUILD_DIR)/%.elf | $(BUILD_DIR)
	@$(HEX) $< $@

$(BUILD_DIR)/%.bin: $(BUILD_DIR)/%.elf | $(BUILD_DIR)
	@$(BIN) $< $@

$(BUILD_DIR):
	mkdir $@


####################################################################################################
.phony: load clean test

load: $(BUILD_DIR)/$(TARGET).elf $(OBJECTS)
	$(OCD) -f $(OCDSCRIPT) -c 'init; halt; program $(BUILD_DIR)/$(TARGET).hex verify; reset; wlink_reset_resume; exit;'

clean:
	@rm -rf $(BUILD_DIR)

test:
	@echo SRC L$(SRC_DIRS)O ahahaha 
	@echo C L$(C_SOURCES)O
	@echo CPP L$(CPP_SOURCES)O
	@echo ASM L$(ASM_SOURCES)O
	@echo OBJ L$(OBJECTS)O

####################################################################################################
# dependencies
-include $(wildcard $(BUILD_DIR)/*.d)

